{
    "version": 6,
    "configurePresets": [
        {
            "name": "PL10_LowPower_LAB2_default_conf",
            "binaryDir": "${fileDir}/../../../_build/PL10_LowPower_LAB2/default",
            "generator": "Ninja",
            "toolchainFile": "${fileDir}/.generated/toolchain.cmake",
            "cacheVariables": {
                "CMAKE_USER_MAKE_RULES_OVERRIDE": {
                    "type": "FILEPATH",
                    "value": "${fileDir}/.generated/overrides.cmake"
                },
                "CMAKE_EXPORT_COMPILE_COMMANDS": {
                    "type": "BOOL",
                    "value": "ON"
                }
            }
        },
        {
            "name": "Configure preset using toolchain file",
            "displayName": "Configure preset using toolchain file",
            "description": "Sets Ninja generator, build and install directory",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/out/build/default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_TOOLCHAIN_FILE": "${fileDir}/.generated/toolchain.cmake",
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/out/install/default"
            }
        }
    ]
}